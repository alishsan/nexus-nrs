{
  "schema_version": 1,
  "title": "Nexus-NRS — reference Woods–Saxon style parameters",
  "units": {
    "energy": "MeV",
    "length": "fm",
    "lab_energy": "MeV (projectile kinetic, target at rest unless noted)"
  },
  "convention": {
    "real_vector": "[V0, R0, a0] — MeV depth, radius, diffuseness. Same order as `functions.clj` / web dashboard: interior potential uses V(r) = -V0/(1 + exp((r - R0)/a0)) plus Coulomb from R0 as charge radius in that code path.",
    "imaginary_vector": "[W0, R_W, a_W] — optional volume imaginary Woods–Saxon (MeV, fm, fm). Bound to `*elastic-imag-ws-params*` for elastic when W0 > 0.",
    "disclaimer": "These are schematic or tutorial-scale sets, not a substitute for experimental OM fits. Check `source` / `reference` on each entry."
  },
  "entries": [
    {
      "id": "tutorial_light_nucleus",
      "purpose": "elastic_om",
      "projectile": "p",
      "target": {"symbol": "16O", "A": 16, "Z": 8},
      "label": "Web dashboard & tutorial default (light target)",
      "energy_lab_MeV_typical": [5, 30],
      "real": {"V0": 40, "R0": 2.0, "a0": 0.6},
      "ws_vector_real": [40.0, 2.0, 0.6],
      "imaginary": null,
      "source": "nexus-nrs web-dashboard default_parameters; examples/example_16Opp_elastic.clj"
    },
    {
      "id": "point_coulomb_matching_only",
      "purpose": "elastic_om",
      "projectile": "any_charged",
      "target": {"symbol": "any", "A": null, "Z": null},
      "label": "Point Coulomb only (no nuclear WS; matching radius from a0)",
      "energy_lab_MeV_typical": null,
      "real": {"V0": 0, "R0": 0, "a0": 0.67},
      "ws_vector_real": [0.0, 0.0, 0.67],
      "imaginary": null,
      "source": "examples/example_alpha_Sm148_elastic.clj (commented); sanity dσ/σ_Ruth = 1"
    },
    {
      "id": "alpha_148Sm_elastic_example",
      "purpose": "elastic_om",
      "projectile": "alpha",
      "target": {"symbol": "148Sm", "A": 148, "Z": 62},
      "label": "Heavy-target α elastic (example script)",
      "energy_lab_MeV_typical": [50],
      "real": {"V0": 65, "R0": 7.5, "a0": 0.67},
      "ws_vector_real": [65.0, 7.5, 0.67],
      "imaginary": {"W0": 3.0, "R_W": 7.5, "a_W": 0.67},
      "ws_vector_imaginary": [3.0, 7.5, 0.67],
      "source": "examples/example_alpha_Sm148_elastic.clj (active defaults)"
    },
    {
      "id": "p_12C_schematic",
      "purpose": "elastic_om",
      "projectile": "p",
      "target": {"symbol": "12C", "A": 12, "Z": 6},
      "label": "Schematic global-style p + C (mid mass)",
      "energy_lab_MeV_typical": [20, 50],
      "real": {"V0": 52, "R0": 2.9, "a0": 0.65},
      "ws_vector_real": [52.0, 2.9, 0.65],
      "imaginary": {"W0": 8.0, "R_W": 2.9, "a_W": 0.65},
      "ws_vector_imaginary": [8.0, 2.9, 0.65],
      "reference": "Order-of-magnitude volume + surface-style W; tune to data",
      "source": "schematic (r0 A^(1/3) with r0≈1.25 fm)"
    },
