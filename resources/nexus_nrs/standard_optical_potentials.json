    },
    {
      "id": "p_208Pb_surface_schematic",
      "purpose": "elastic_om",
      "projectile": "p",
      "target": {"symbol": "208Pb", "A": 208, "Z": 82},
      "label": "Heavy target p + 208Pb (schematic volume real + volume imag)",
      "energy_lab_MeV_typical": [20, 50],
      "real": {"V0": 58, "R0": 7.35, "a0": 0.63},
      "ws_vector_real": [58.0, 7.35, 0.63],
      "imaginary": {"W0": 12.0, "R_W": 7.35, "a_W": 0.63},
